# Google OAuth client ID (matches RAG_GOOGLE_CLIENT_ID on the backend)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Backend API base URL — must point to your Cloud Run service URL in production
# In local dev, leave blank: Vite proxy rewrites /api → http://localhost:8000
VITE_API_BASE_URL=https://your-cloud-run-service-url.a.run.app

# Dev only — backend target for Vite dev proxy (not baked into the build)
# VITE_DEV_BACKEND_URL=http://localhost:8000
